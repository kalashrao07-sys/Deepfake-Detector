# ============================================================
# Environment Variables - Backend Configuration
# ============================================================

# Server Port
PORT=5000

# MySQL Database Configuration (XAMPP defaults)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME = your_database_name_here

# JWT Secret (used for session tokens)
JWT_SECRET = YourJWTSecretKeyHere

# Frontend URL (for CORS)
FRONTEND_URL = http://localhost:3000

# ---- Sightengine API (Images & Videos) ----
SIGHTENGINE_USER = your_sightengine_user_id_here
SIGHTENGINE_SECRET = your_sightengine_secret_key_here

# ---- Gemini API (PDF, PPT, DOCX, TXT) ----
GEMINI_API_KEY = your_gemini_api_key_here
