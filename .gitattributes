# Force React components to register as JSX (React)
frontend/src/components/*.js linguist-language=JSX
frontend/src/pages/*.js linguist-language=JSX
frontend/src/App.js linguist-language=JSX
frontend/src/index.js linguist-language=JSX

# Keep backend and shared API logic mapped as native JavaScript
backend/**/*.js linguist-language=JavaScript
frontend/src/services/*.js linguist-language=JavaScript

# Exclude documents from code metrics
database.sql linguist-documentation
README.md linguist-documentation
